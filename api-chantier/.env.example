# Used by docker compose (and local overrides)

POSTGRES_USER=chantier
POSTGRES_PASSWORD=chantier
POSTGRES_DB=chantier
POSTGRES_PORT=5432

API_PORT=3000

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Local node (outside Docker) — host maps to published Postgres port
DATABASE_URL=postgres://chantier:chantier@localhost:5432/chantier
PORT=3000
NODE_ENV=development

# Imp-09 SSE (optional)
SSE_HEARTBEAT_MS=30000
SSE_RETRY_MS=3000
