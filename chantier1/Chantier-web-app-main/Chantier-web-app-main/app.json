{
  "expo": {
    "name": "Chantier",
    "slug": "bolt-expo-nativewind",
    "extra": {
      "eas": {
        "projectId": "b7c53041-958a-4ad7-92e3-45a6178050e4"
      }
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/chantier.png",
    "splash": {
      "image": "./assets/images/chantier.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "Chantier"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.kieunghi.boltexponativewind",
      "label": "Chantier",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/chantier.png",
        "backgroundColor": "#FF6B35"
      }
    }
  }
}
